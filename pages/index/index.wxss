/* 首页样式 */

.page {
  padding: 20rpx;
  padding-bottom: 140rpx;
}

/* ===== 月份选择器 ===== */
.month-selector {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0 24rpx;
}

.month-arrow {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #4CAF50;
  background: #fff;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.arrow-disabled {
  color: #ccc;
}

.month-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin: 0 40rpx;
  min-width: 180rpx;
  text-align: center;
}

/* ===== 汇总卡片 ===== */
.summary-card {
  background: linear-gradient(135deg, #43A047, #66BB6A);
  border-radius: 20rpx;
  padding: 36rpx 30rpx;
  color: #fff;
  margin-bottom: 20rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.summary-label {
  font-size: 24rpx;
  opacity: 0.85;
  margin-bottom: 8rpx;
}

.summary-value {
  font-size: 36rpx;
  font-weight: bold;
}

.summary-card .money-income {
  color: #C8E6C9;
}

.summary-card .money-expense {
  color: #FFCDD2;
}

/* ===== 添加按钮 ===== */
.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.add-btn-icon {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  background: #4CAF50;
  color: #fff;
  border-radius: 50%;
  font-size: 36rpx;
  font-weight: bold;
  margin-right: 16rpx;
}

.add-btn-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

/* ===== 通用卡片 ===== */
.section-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.section-sub {
  font-size: 24rpx;
  color: #999;
}

.section-more {
  font-size: 26rpx;
  color: #4CAF50;
}

/* ===== 分类排行 ===== */
.category-list {
  /* 无额外样式，由子元素撑开 */
}

.category-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.cat-emoji {
  font-size: 32rpx;
  margin-right: 10rpx;
  width: 44rpx;
  text-align: center;
}

.cat-name {
  font-size: 26rpx;
  color: #333;
  width: 80rpx;
  flex-shrink: 0;
}

.cat-bar-wrapper {
  flex: 1;
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  margin: 0 12rpx;
  overflow: hidden;
}

.cat-bar {
  height: 100%;
  background: linear-gradient(90deg, #F44336, #EF5350);
  border-radius: 6rpx;
  transition: width 0.4s ease;
}

.cat-amount {
  font-size: 24rpx;
  color: #666;
  width: 100rpx;
  text-align: right;
  flex-shrink: 0;
}

.cat-percent {
  font-size: 22rpx;
  color: #999;
  width: 60rpx;
  text-align: right;
  flex-shrink: 0;
}

/* 无支出空状态 */
.mini-empty {
  text-align: center;
  padding: 30rpx 0;
  font-size: 26rpx;
  color: #bbb;
}

/* ===== 空状态 ===== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* ===== 记录列表 ===== */
.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-left {
  display: flex;
  align-items: center;
}

.record-emoji {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.record-info {
  display: flex;
  flex-direction: column;
}

.record-category {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.record-date {
  font-size: 22rpx;
  color: #999;
}

.record-amount {
  font-size: 32rpx;
  font-weight: bold;
}
