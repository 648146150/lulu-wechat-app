.page{padding:24rpx;}
.hero{background:linear-gradient(135deg,#FF9800,#FFB74D);border-radius:28rpx;padding:36rpx;margin-bottom:24rpx;color:#fff;text-align:center;}
.hl{font-size:24rpx;opacity:0.85;}.hv{font-size:72rpx;font-weight:300;margin:12rpx 0;display:block;}
.hs{display:flex;justify-content:center;gap:40rpx;font-size:24rpx;opacity:0.8;}
.bar{display:flex;justify-content:space-between;align-items:center;margin-bottom:20rpx;}
.bt{font-size:32rpx;font-weight:700;color:#333;}.ba{font-size:28rpx;color:#4CAF50;}
.empty{text-align:center;padding:60rpx 0;}.ei{font-size:72rpx;display:block;margin-bottom:16rpx;}.et{font-size:26rpx;color:#999;}
.item{display:flex;align-items:center;background:#fff;border-radius:24rpx;padding:24rpx;margin-bottom:12rpx;}
.im{width:72rpx;height:72rpx;border-radius:20rpx;display:flex;align-items:center;justify-content:center;font-size:36rpx;flex-shrink:0;}
.im.bank{background:#E3F2FD;}.im.stock{background:#FFF3E0;}.im.fund{background:#E8F5E9;}.im.forex{background:#E8F5E9;}.im.cash{background:#F3E5F5;}.im.other{background:#ECEFF1;}
.if{flex:1;margin-left:20rpx;overflow:hidden;}
.in{font-size:28rpx;font-weight:600;color:#333;display:block;}
.it{font-size:22rpx;color:#999;margin-top:4rpx;display:block;}
.ir{text-align:right;flex-shrink:0;}
.iv{font-size:30rpx;font-weight:600;display:block;}
.iv.green{color:#4CAF50;}.iv.red{color:#F44336;}
.ic{font-size:22rpx;color:#999;display:block;margin-top:4rpx;}
.ia{margin-top:6rpx;display:flex;gap:12rpx;justify-content:flex-end;font-size:28rpx;}
.form-overlay{display:none;position:fixed;top:0;right:0;bottom:0;left:0;background:rgba(0,0,0,0.4);z-index:999;}
.form-overlay.show{display:flex;align-items:flex-end;}
.form-sheet{width:100%;background:#fff;border-radius:40rpx 40rpx 0 0;padding:40rpx 40rpx 80rpx;box-sizing:border-box;}
.ft{font-size:32rpx;font-weight:700;color:#333;text-align:center;margin-bottom:36rpx;display:block;}
.fg{margin-bottom:28rpx;}
.fl{font-size:28rpx;color:#666;margin-bottom:14rpx;display:block;}
.fi{width:100%;height:76rpx;padding:0 24rpx;font-size:28rpx;color:#333;background:#f5f5f5;border-radius:16rpx;box-sizing:border-box;line-height:76rpx;}
.tt{display:flex;flex-wrap:wrap;gap:16rpx;}
.tg{padding:16rpx 28rpx;font-size:26rpx;color:#666;background:#f5f5f5;border-radius:36rpx;display:flex;align-items:center;gap:10rpx;}
.tg.active{background:#E8F5E9;color:#4CAF50;font-weight:600;}
.tgi{font-size:28rpx;}
.fx-rate{font-size:24rpx;color:#999;margin-top:14rpx;display:block;}
.fb{display:flex;gap:20rpx;margin-top:16rpx;}
.fbc{flex:1;background:#f5f5f5;border:none;border-radius:20rpx;padding:20rpx;font-size:28rpx;color:#999;text-align:center;}
.fbs{flex:1;background:#4CAF50;border:none;border-radius:20rpx;padding:20rpx;font-size:28rpx;color:#fff;text-align:center;}
button{border:none;margin:0;padding:0;}button::after{border:none;}
