.page{padding:24rpx 24rpx 160rpx;}
.hero{background:linear-gradient(135deg,#FF9800,#FFB74D);border-radius:36rpx;padding:48rpx;margin-bottom:32rpx;color:#fff;text-align:center;}
.hl{font-size:26rpx;opacity:0.85;}.hv{font-size:88rpx;font-weight:300;margin:16rpx 0;display:block;}
.hs{display:flex;justify-content:center;gap:56rpx;font-size:26rpx;opacity:0.8;}
.bar{display:flex;justify-content:space-between;align-items:center;margin-bottom:20rpx;}
.bt{font-size:32rpx;font-weight:700;color:#333;}.ba{font-size:28rpx;color:#4CAF50;}
.empty{text-align:center;padding:120rpx 0;}.ei{font-size:100rpx;display:block;margin-bottom:24rpx;}.et{font-size:28rpx;color:#999;}
.item{display:flex;align-items:center;background:#fff;border-radius:28rpx;padding:28rpx 24rpx;margin-bottom:14rpx;}
.im{width:88rpx;height:88rpx;border-radius:24rpx;display:flex;align-items:center;justify-content:center;font-size:44rpx;flex-shrink:0;}
.im.bank{background:#E3F2FD;}.im.stock{background:#FFF3E0;}.im.fund{background:#E8F5E9;}.im.forex{background:#E8F5E9;}.im.cash{background:#F3E5F5;}.im.other{background:#ECEFF1;}
.if{flex:1;margin-left:24rpx;overflow:hidden;}
.in{font-size:30rpx;font-weight:600;color:#333;display:block;}
.it{font-size:24rpx;color:#999;margin-top:6rpx;display:block;}
.ir{text-align:right;flex-shrink:0;}
.iv{font-size:32rpx;font-weight:600;display:block;}
.iv.green{color:#4CAF50;}.iv.red{color:#F44336;}
.ia{margin-top:8rpx;display:flex;gap:14rpx;justify-content:flex-end;font-size:30rpx;}
.form-overlay{display:none;position:fixed;top:0;right:0;bottom:0;left:0;background:rgba(0,0,0,0.4);z-index:999;}
.form-overlay.show{display:flex;align-items:flex-end;}
.form-sheet{width:100%;background:#fff;border-radius:40rpx 40rpx 0 0;padding:40rpx 36rpx 80rpx;box-sizing:border-box;}
.ft{font-size:36rpx;font-weight:700;color:#333;text-align:center;margin-bottom:40rpx;display:block;}
.fg{margin-bottom:32rpx;}
.fl{font-size:26rpx;color:#999;margin-bottom:14rpx;display:block;}
.fi{width:100%;padding:24rpx 20rpx;font-size:30rpx;color:#333;background:#f5f5f5;border-radius:20rpx;box-sizing:border-box;}
.tt{display:flex;flex-wrap:wrap;gap:16rpx;}
.tg{padding:18rpx 28rpx;font-size:26rpx;color:#666;background:#f5f5f5;border-radius:36rpx;}
.tg.active{background:#E8F5E9;color:#4CAF50;font-weight:600;}
.fb{display:flex;gap:20rpx;margin-top:24rpx;}
.fbc{flex:1;background:#f5f5f5;border-radius:24rpx;padding:28rpx;font-size:32rpx;color:#999;text-align:center;}
.fbs{flex:1;background:#4CAF50;border-radius:24rpx;padding:28rpx;font-size:32rpx;color:#fff;text-align:center;}
button{border:none;margin:0;padding:0;}button::after{border:none;}
