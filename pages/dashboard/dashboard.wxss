.page { padding: 24rpx; }

.time-row { display: flex; align-items: baseline; justify-content: space-between; padding: 12rpx 8rpx 28rpx; }
.time-date { font-size: 52rpx; font-weight: 700; color: #333; }
.time-week { font-size: 28rpx; color: #999; margin-left: 16rpx; }
.time-clock { font-size: 44rpx; font-weight: 600; color: #333; }

.weather-strip { background: linear-gradient(135deg, #4A90D9, #6DB3F2); border-radius: 28rpx; padding: 32rpx 36rpx; margin-bottom: 28rpx; display: flex; align-items: center; color: #fff; }
.w-emoji { font-size: 80rpx; margin-right: 20rpx; }
.w-temp { font-size: 64rpx; font-weight: 300; margin-right: 20rpx; }
.w-desc { font-size: 30rpx; }
.w-city { font-size: 22rpx; opacity: 0.65; margin-top: 4rpx; }
.w-meta { margin-left: auto; text-align: right; font-size: 22rpx; opacity: 0.65; line-height: 1.6; }

.tool-grid { display: flex; flex-wrap: wrap; margin-bottom: 28rpx; }
.tool-card { width: calc(50% - 10rpx); margin: 0 20rpx 20rpx 0; background: #fff; border-radius: 28rpx; padding: 36rpx 28rpx; box-sizing: border-box; }
.tool-card:nth-child(2n) { margin-right: 0; }
.card-icon { font-size: 64rpx; margin-bottom: 14rpx; display: block; }
.card-label { font-size: 28rpx; font-weight: 700; color: #333; margin-bottom: 10rpx; display: block; }
.card-value { font-weight: 600; font-size: 44rpx; display: block; margin-bottom: 6rpx; }
.card-sub { font-size: 22rpx; color: #999; display: block; }
.card-bookkeeping { border-top: 5rpx solid #4CAF50; } .card-bookkeeping .card-value { color: #4CAF50; }
.card-assets { border-top: 5rpx solid #FF9800; } .card-assets .card-value { color: #FF9800; }
.card-steps { border-top: 5rpx solid #2196F3; } .card-steps .card-value { color: #2196F3; }
.card-period { border-top: 5rpx solid #E91E63; } .card-period .card-value { color: #E91E63; }
.card-custom { border-top: 5rpx solid #9C27B0; } .card-custom .card-value { color: #9C27B0; }

.quick-card { background: #fff; border-radius: 28rpx; padding: 32rpx 36rpx; }
.qc-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 28rpx; }
.qc-title { font-size: 30rpx; font-weight: 700; color: #333; }
.qc-more { font-size: 26rpx; color: #4CAF50; }
.qc-row { display: flex; justify-content: space-around; text-align: center; }
.qc-value { font-size: 40rpx; font-weight: 700; display: block; }
.qc-label { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }
.green { color: #4CAF50; } .red { color: #F44336; }
