/* 记账页样式 */

.page {
  padding: 20rpx;
  padding-bottom: 140rpx;
}

/* ===== 收入/支出切换 ===== */
.type-switch {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
}

.type-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}

.type-item.active {
  color: #fff;
  font-weight: bold;
}

.type-item.expense-active {
  background: #F44336;
}

.type-item.income-active {
  background: #4CAF50;
}

/* ===== 金额输入 ===== */
.amount-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.amount-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.amount-input-wrapper {
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid #4CAF50;
  padding-bottom: 12rpx;
}

.amount-symbol {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-right: 12rpx;
}

.amount-input {
  flex: 1;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

/* ===== 分类选择 ===== */
.category-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.section-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
}

.category-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.category-item.selected {
  background: #E8F5E9;
}

.category-emoji {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.category-name {
  font-size: 24rpx;
  color: #666;
}

/* ===== 备注 ===== */
.note-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.note-input {
  font-size: 28rpx;
  color: #333;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #eee;
}

/* ===== 日期 ===== */
.date-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 48rpx;
}

.date-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #333;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #eee;
}

.date-arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* ===== 保存按钮 ===== */
.save-section {
  padding: 0 40rpx;
}

.save-btn {
  width: 100%;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  padding: 24rpx 0;
  border: none;
}

.save-expense {
  background: linear-gradient(135deg, #F44336, #EF5350);
}

.save-income {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
}
