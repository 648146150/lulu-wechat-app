<!-- 记账页 - 添加收入/支出记录 -->
<view class="page">

  <!-- ===== 收入/支出切换 ===== -->
  <view class="type-switch">
    <view class="type-item {{type === 'expense' ? 'active expense-active' : ''}}"
          bindtap="switchType" data-type="expense">
      <text>支出</text>
    </view>
    <view class="type-item {{type === 'income' ? 'active income-active' : ''}}"
          bindtap="switchType" data-type="income">
      <text>收入</text>
    </view>
  </view>

  <!-- ===== 金额输入 ===== -->
  <view class="amount-section">
    <view class="amount-label">金额（元）</view>
    <view class="amount-input-wrapper">
      <text class="amount-symbol">¥</text>
      <input class="amount-input"
             type="digit"
             placeholder="0.00"
             value="{{amount}}"
             bindinput="onAmountInput"
             focus="{{true}}" />
    </view>
  </view>

  <!-- ===== 分类选择 ===== -->
  <view class="category-section">
    <view class="section-label">选择分类</view>
    <view class="category-grid">
      <view class="category-item {{selectedCategory === item.name ? 'selected' : ''}}"
            wx:for="{{categories}}"
            wx:key="name"
            bindtap="selectCategory"
            data-name="{{item.name}}">
        <text class="category-emoji">{{item.emoji}}</text>
        <text class="category-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- ===== 备注 ===== -->
  <view class="note-section">
    <view class="section-label">备注（选填）</view>
    <input class="note-input"
           placeholder="写点什么..."
           value="{{note}}"
           bindinput="onNoteInput" />
  </view>

  <!-- ===== 日期 ===== -->
  <view class="date-section">
    <view class="section-label">日期</view>
    <picker mode="date" value="{{date}}" bindchange="onDateChange">
      <view class="date-picker">
        <text>{{date}}</text>
        <text class="date-arrow">›</text>
      </view>
    </picker>
  </view>

  <!-- ===== 保存按钮 ===== -->
  <view class="save-section">
    <button class="save-btn {{type === 'income' ? 'save-income' : 'save-expense'}}"
            bindtap="saveRecord">
      保存
    </button>
  </view>

  <!-- ===== 底部导航栏 ===== -->
  <view class="tab-bar">
    <view class="tab-item" bindtap="goToIndex">
      <text class="tab-icon">🏠</text>
      <text class="tab-label">首页</text>
    </view>
    <view class="tab-item active">
      <text class="tab-icon">➕</text>
      <text class="tab-label">记账</text>
    </view>
    <view class="tab-item" bindtap="goToHistory">
      <text class="tab-icon">📋</text>
      <text class="tab-label">账单</text>
    </view>
  </view>

</view>
