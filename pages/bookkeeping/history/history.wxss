.page{padding:24rpx;}
.month-bar{display:flex;align-items:center;background:#fff;border-radius:24rpx;padding:20rpx 24rpx;margin-bottom:24rpx;}
.mb-btn{width:56rpx;height:56rpx;display:flex;align-items:center;justify-content:center;font-size:26rpx;color:#4CAF50;}
.mb-btn.disabled{color:#ccc;}.mb-text{font-size:30rpx;font-weight:700;color:#333;margin:0 16rpx;}
.mbs{margin-left:auto;display:flex;gap:20rpx;}.mi{font-size:24rpx;color:#4CAF50;}.mo{font-size:24rpx;color:#F44336;}
.empty{display:flex;flex-direction:column;align-items:center;padding:120rpx 0;}.ei{font-size:100rpx;margin-bottom:20rpx;}.et{font-size:28rpx;color:#999;margin-bottom:40rpx;}
.eb{background:#4CAF50;color:#fff;padding:16rpx 60rpx;border-radius:40rpx;font-size:28rpx;}
.group{margin-bottom:20rpx;}
.gh{display:flex;justify-content:space-between;align-items:center;padding:16rpx 8rpx;}.gd{font-size:28rpx;font-weight:700;color:#333;}.gs{font-size:22rpx;color:#999;}
.grs{background:#fff;border-radius:18rpx;overflow:hidden;}
.ri{display:flex;justify-content:space-between;align-items:center;padding:24rpx 20rpx;border-bottom:1rpx solid #f8f8f8;}
.ri:last-child{border-bottom:none;}
.rl{display:flex;align-items:center;}.re{font-size:40rpx;margin-right:16rpx;}.rif{display:flex;flex-direction:column;}.rc{font-size:28rpx;color:#333;}.rn{font-size:22rpx;color:#aaa;margin-top:4rpx;}
.ra{font-size:32rpx;font-weight:700;}
.tip{text-align:center;padding:40rpx 0;font-size:24rpx;color:#bbb;}
