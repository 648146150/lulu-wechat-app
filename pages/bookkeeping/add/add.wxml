<view class="page">
  <view class="type-switch">
    <view class="ts-item {{type==='expense'?'active expense':''}}" bindtap="switchType" data-type="expense"><text>支出</text></view>
    <view class="ts-item {{type==='income'?'active income':''}}" bindtap="switchType" data-type="income"><text>收入</text></view>
  </view>
  <view class="amount">
    <text class="al">金额（元）</text>
    <view class="aw"><text class="as">¥</text><input class="ai" type="digit" placeholder="0.00" value="{{amount}}" bindinput="onAmount"/></view>
  </view>
  <view class="section">
    <text class="sl">选择分类</text>
    <view class="grid">
      <view class="gi {{selectedCategory===item.name?'sel':''}}" wx:for="{{categories}}" wx:key="name" bindtap="selCat" data-name="{{item.name}}">
        <text class="ge">{{item.emoji}}</text><text class="gn">{{item.name}}</text>
      </view>
    </view>
  </view>
  <view class="section"><text class="sl">备注（选填）</text><input class="inp" placeholder="写点什么..." value="{{note}}" bindinput="onNote"/></view>
  <view class="section">
    <text class="sl">日期</text>
    <picker mode="date" value="{{date}}" bindchange="onDate"><view class="dp"><text>{{date}}</text><text class="da">›</text></view></picker>
  </view>
  <view class="save"><button class="sb {{type==='income'?'si':'se'}}" bindtap="saveRecord">保存</button></view>
  </view>
