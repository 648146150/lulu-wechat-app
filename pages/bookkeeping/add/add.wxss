.page{padding:24rpx 24rpx 160rpx;}
.type-switch{display:flex;background:#fff;border-radius:24rpx;padding:8rpx;margin-bottom:28rpx;}
.ts-item{flex:1;text-align:center;padding:20rpx 0;border-radius:20rpx;font-size:28rpx;color:#666;}
.ts-item.active{color:#fff;font-weight:700;}.ts-item.expense{background:#F44336;}.ts-item.income{background:#4CAF50;}
.amount{background:#fff;border-radius:28rpx;padding:32rpx;margin-bottom:28rpx;}
.al{font-size:26rpx;color:#999;margin-bottom:20rpx;display:block;}
.aw{display:flex;align-items:center;border-bottom:3rpx solid #4CAF50;padding-bottom:16rpx;}
.as{font-size:56rpx;font-weight:700;color:#333;margin-right:16rpx;}
.ai{flex:1;font-size:56rpx;font-weight:700;color:#333;}
.section{background:#fff;border-radius:28rpx;padding:32rpx;margin-bottom:28rpx;}
.sl{font-size:26rpx;color:#999;margin-bottom:20rpx;display:block;}
.grid{display:flex;flex-wrap:wrap;}
.gi{width:25%;display:flex;flex-direction:column;align-items:center;padding:20rpx 0;border-radius:20rpx;}
.gi.sel{background:#E8F5E9;}
.ge{font-size:52rpx;margin-bottom:10rpx;}.gn{font-size:26rpx;color:#666;}
.inp{font-size:28rpx;color:#333;padding:16rpx 0;border-bottom:1rpx solid #eee;}
.dp{display:flex;justify-content:space-between;align-items:center;font-size:28rpx;color:#333;padding:16rpx 0;border-bottom:1rpx solid #eee;}
.da{font-size:40rpx;color:#ccc;}
.save{padding:0 60rpx;margin-top:48rpx;}
.sb{width:100%;border-radius:50rpx;font-size:32rpx;font-weight:700;color:#fff;padding:28rpx 0;text-align:center;}
.se{background:linear-gradient(135deg,#F44336,#EF5350);}.si{background:linear-gradient(135deg,#4CAF50,#66BB6A);}
button{border:none;margin:0;padding:0;}button::after{border:none;}
