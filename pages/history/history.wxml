<!-- 账单列表页 - 按月份筛选，按日期分组 -->
<view class="page">

  <!-- ===== 月份选择器 ===== -->
  <view class="month-bar">
    <view class="month-arrow" bindtap="prevMonth">◀</view>
    <text class="month-text">{{currentYear}}年{{currentMonth}}月</text>
    <view class="month-arrow {{isCurrentMonth ? 'arrow-disabled' : ''}}"
          bindtap="nextMonth">▶</view>
    <view class="month-summary-wrap">
      <text class="month-in">收 {{monthIncome}}</text>
      <text class="month-out">支 {{monthExpense}}</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{groups.length === 0}}">
    <text class="empty-icon">📭</text>
    <text class="empty-text">{{currentMonth}}月还没有账单记录</text>
    <view class="empty-btn" bindtap="goToAdd">去记一笔</view>
  </view>

  <!-- 按日期分组 -->
  <view class="group-list" wx:else>
    <view class="group" wx:for="{{groups}}" wx:key="date">

      <view class="group-header">
        <text class="group-date">{{item.date}}</text>
        <text class="group-summary">
          收入 {{item.dayIncome}} | 支出 {{item.dayExpense}}
        </text>
      </view>

      <view class="group-records">
        <view class="record-item"
              wx:for="{{item.records}}"
              wx:for-item="record"
              wx:key="id"
              bindlongpress="deleteRecord"
              data-id="{{record.id}}">
          <view class="record-left">
            <text class="record-emoji">{{record.categoryEmoji}}</text>
            <view class="record-info">
              <text class="record-category">{{record.category}}</text>
              <text class="record-note" wx:if="{{record.note}}">{{record.note}}</text>
            </view>
          </view>
          <text class="record-amount {{record.type === 'income' ? 'money-income' : 'money-expense'}}">
            {{record.type === 'income' ? '+' : '-'}}{{record.amount}}
          </text>
        </view>
      </view>

    </view>
  </view>

  <!-- 底部提示 -->
  <view class="history-tip" wx:if="{{groups.length > 0}}">
    <text>长按任意记录可删除</text>
  </view>

  <!-- ===== 底部导航栏 ===== -->
  <view class="tab-bar">
    <view class="tab-item" bindtap="goToIndex">
      <text class="tab-icon">🏠</text>
      <text class="tab-label">首页</text>
    </view>
    <view class="tab-item" bindtap="goToAdd">
      <text class="tab-icon">➕</text>
      <text class="tab-label">记账</text>
    </view>
    <view class="tab-item active">
      <text class="tab-icon">📋</text>
      <text class="tab-label">账单</text>
    </view>
  </view>

</view>
