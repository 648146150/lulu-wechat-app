.page{padding:32rpx 32rpx 160rpx;}
.info{text-align:center;font-size:26rpx;color:#999;margin-bottom:24rpx;}
.slot-row{display:flex;align-items:center;background:#fff;border-radius:28rpx;padding:28rpx 24rpx;margin-bottom:16rpx;}
.sn{font-size:40rpx;font-weight:700;color:#ddd;width:56rpx;text-align:center;}
.si{font-size:56rpx;margin:0 24rpx;}
.sn2{flex:1;font-size:30rpx;font-weight:600;color:#333;}
.sl{font-size:24rpx;color:#ccc;}
.sb{font-size:26rpx;color:#4CAF50;padding:10rpx 28rpx;border:2rpx solid #4CAF50;border-radius:28rpx;}
.sd{font-size:44rpx;color:#ddd;margin-left:20rpx;}
.add{text-align:center;border:4rpx dashed #ddd;border-radius:28rpx;padding:36rpx;color:#4CAF50;font-size:30rpx;font-weight:600;}
.max{text-align:center;color:#bbb;font-size:26rpx;padding:32rpx;}
.modal{display:none;position:fixed;top:0;right:0;bottom:0;left:0;background:rgba(0,0,0,0.4);z-index:999;}
.modal.show{display:flex;align-items:flex-end;}
.mc{width:100%;background:#fff;border-radius:40rpx 40rpx 0 0;padding:40rpx 32rpx 80rpx;}
.mt{font-size:34rpx;font-weight:700;color:#333;text-align:center;margin-bottom:28rpx;display:block;}
.po{display:flex;align-items:center;padding:24rpx 12rpx;border-radius:24rpx;margin-bottom:8rpx;}
.poi{font-size:52rpx;margin-right:24rpx;}
.pof{flex:1;}
.pon{font-size:30rpx;font-weight:600;color:#333;display:block;}
.pod{font-size:24rpx;color:#999;}
.poc{font-size:36rpx;color:#4CAF50;}
.pc{width:100%;background:#f5f5f5;border-radius:28rpx;padding:28rpx;font-size:30rpx;color:#999;margin-top:16rpx;text-align:center;}
button{border:none;margin:0;padding:0;}button::after{border:none;}
