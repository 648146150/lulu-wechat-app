.page{padding:24rpx 24rpx 160rpx;}
.hero{background:linear-gradient(135deg,#E91E63,#F06292);border-radius:36rpx;padding:48rpx;margin-bottom:32rpx;color:#fff;text-align:center;}
.hl{font-size:26rpx;opacity:0.85;}.hv{font-size:96rpx;font-weight:200;display:block;margin:16rpx 0;}.hi{font-size:26rpx;opacity:0.8;}
.card{background:#fff;border-radius:32rpx;padding:32rpx;margin-bottom:28rpx;}
.cn{display:flex;align-items:center;justify-content:center;margin-bottom:24rpx;gap:40rpx;}
.ca{font-size:28rpx;color:#4CAF50;}.ca.disabled{color:#ccc;}.ct{font-size:32rpx;font-weight:700;color:#333;}
.cg{display:grid;grid-template-columns:repeat(7,1fr);gap:8rpx;text-align:center;}
.ch{font-size:24rpx;color:#999;padding:12rpx 0;}
.cd{font-size:28rpx;color:#333;padding:16rpx 0;border-radius:50%;}
.cd.period{background:#FCE4EC;color:#E91E63;font-weight:700;}
.cd.predicted{background:#FFF3E0;color:#FF9800;}
.cd.today{border:4rpx solid #E91E63;}
.cl{display:flex;gap:32rpx;margin-top:20rpx;font-size:24rpx;color:#999;}
.ct2{font-size:32rpx;font-weight:700;color:#333;margin-bottom:24rpx;display:block;}
.hi2{display:flex;justify-content:space-between;align-items:center;padding:20rpx 0;border-bottom:1rpx solid #f5f5f5;font-size:28rpx;}
.hd{font-size:32rpx;}
