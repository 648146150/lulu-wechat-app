page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
}
.money-income { color: #4CAF50; font-weight: bold; }
.money-expense { color: #F44336; font-weight: bold; }
.home-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  height: 120rpx; background: #fff; border-top: 1rpx solid #eee;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
}
.home-bar .icon { font-size: 44rpx; display: block; }
.home-bar .text { font-size: 22rpx; color: #4CAF50; display: block; margin-top: 2rpx; }
