/* 全局样式 - 所有页面共用 */

/* 页面背景 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  padding-bottom: 120rpx;  /* 给底部导航栏留出空间 */
  box-sizing: border-box;
}

/* ===== 底部导航栏（三页面共用） ===== */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background-color: #ffffff;
  border-top: 1rpx solid #eeeeee;
  z-index: 999;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
  font-size: 22rpx;
  color: #999999;
  text-decoration: none;
}

.tab-item.active {
  color: #4CAF50;
}

.tab-item .tab-icon {
  font-size: 44rpx;
  margin-bottom: 2rpx;
}

.tab-item .tab-label {
  font-size: 20rpx;
}

/* ===== 金额显示规范 ===== */
.money-income {
  color: #4CAF50;
  font-weight: bold;
}

.money-expense {
  color: #F44336;
  font-weight: bold;
}
